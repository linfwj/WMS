<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.ken.wms.dao.RolePermissionMapper">
    
    <resultMap id="rolePermissionResultMap" type="com.ken.wms.domain.RolePermissionDO">
        <result column="URL" property="url"/>
        <result column="ROLE" property="role"/>
    </resultMap>

    <select id="selectAll" resultMap="rolePermissionResultMap">
        SELECT DISTINCT r.ROLE_URL_PREFIX as URL, r.ROLE_NAME as ROLE
        FROM wms_roles r
        WHERE r.ROLE_URL_PREFIX IS NOT NULL
        ORDER BY r.ROLE_ID ASC
    </select>
</mapper>
